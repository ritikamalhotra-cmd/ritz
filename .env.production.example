# Copy this to .env.production and fill in values before first deploy
# deploy.sh will auto-generate secrets marked with "change_this"

DB_PASSWORD=change_this
JWT_ACCESS_SECRET=change_this
JWT_REFRESH_SECRET=change_this

FRONTEND_URL=https://offertool.dotpe.in
COOKIE_DOMAIN=offertool.dotpe.in

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_FROM=no-reply@dotpe.in
