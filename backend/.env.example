NODE_ENV=development
PORT=4000
DATABASE_URL="file:./dev.db"

# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=dev-access-secret-replace-before-any-real-use
JWT_REFRESH_SECRET=dev-refresh-secret-replace-before-any-real-use
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

FRONTEND_URL=http://localhost:5173

GOOGLE_CLIENT_ID=your-google-client-id-here
SSO_DOMAIN=dotpe.in

# Email (leave empty in dev — emails will log to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@dotpe.in

# AWS S3 (leave empty to use local /uploads folder)
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=ap-south-1

# Seed
SEED_ADMIN_EMAIL=admin@dotpe.in
SEED_ADMIN_PASSWORD=Admin@dotpe1

# ATS Candidate Sourcing Sheet (Google Sheets — public view)
SHEETS_ATS_ID=15I9HMa5TIC-ov8-PejOZgVWuDMQIuo0LpJYgxsM4XjI
